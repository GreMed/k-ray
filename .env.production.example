# K-Ray 生产环境变量示例
#
# 使用方式：
#   1. 复制此文件为 .env.production
#   2. 根据实际环境修改配置
#   3. Docker 部署时通过 docker-compose.yml 或 -e 参数注入
#
# 重要：不要将真实的 .env.production 提交到版本控制或打包进 Docker 镜像

# ============================================================================
# Node.js 运行环境
# ============================================================================
NODE_ENV=production

# ============================================================================
# 行情数据模式
# - real: 使用真实 BaoStock 行情（生产默认）
# - mock: 使用 Mock 数据（仅开发/测试）
# - fallback: BaoStock 失败时降级为 Mock（仅开发/测试）
# ============================================================================
MARKET_DATA_MODE=real

# ============================================================================
# 新闻事件数据模式
# - mock: 使用 Mock 新闻数据（当前发布版默认）
# ============================================================================
EVENT_NEWS_MODE=mock

# ============================================================================
# 公告数据模式
# - mock: 使用 Mock 公告数据（当前发布版默认）
# ============================================================================
ANNOUNCEMENT_DATA_MODE=mock

# ============================================================================
# BaoStock Python 子进程路径
# Docker 容器内的标准路径，一般无需修改
# ============================================================================
BAOSTOCK_PYTHON_PATH=/opt/venv/bin/python
BAOSTOCK_SCRIPT_PATH=/app/scripts/baostock_client.py
BAOSTOCK_STOCK_INFO_SCRIPT_PATH=/app/scripts/baostock_stock_info.py

# ============================================================================
# 服务器监听
# ============================================================================
PORT=3000
HOSTNAME=0.0.0.0
