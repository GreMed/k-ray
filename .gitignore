# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/

# production
/build

# release packages（本地打包产物，不上传）
/release/
/reports/

# 截图产物目录（本地验收用，不上传）
# 注意：仅忽略根目录下的截图产物目录，不影响 scripts/ 下的同名验收脚本
/screenshots_*/
/screenshots-*/
/screenshots_archive/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 本地日志和临时文件
*.log
*.tmp
*.bak

# env files (can opt-in for committing if needed)
.env*
# 保留生产环境变量示例文件（发布材料必需）
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python virtual environment
.venv/

# release tar packages
*.tar.gz

# 早期本地材料（不进入正式源码仓库，保留本地文件）
/PHASE2_ACCEPTANCE_REPORT.md
/take_screenshots.js
/take_screenshots_phase3.js
/take_screenshots_phase4.js
/screenshots_phase2_test.js
